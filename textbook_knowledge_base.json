{
  "aliases": {
    "木兰辞": "木兰诗"
  },
  "works": {
    "岳阳楼记": {
      "aliases": [],
      "translation": [
        "庆历四年春天，滕子京被贬到巴陵郡做太守。到了第二年，政事顺利，百姓和乐，许多荒废的事业都重新兴办起来，于是重修岳阳楼，扩充旧有规模，把唐代名家和当代人的诗赋刻在楼上，嘱托我写一篇文章来记述这件事。",
        "我看那巴陵郡的胜景，都集中在洞庭湖。它连接远山，吞纳长江，水势浩大，宽广无边，早晚阴晴变化万千，这就是岳阳楼的壮观景象，前人的描写已经很详尽了。",
        "在连月阴雨、阴风怒号时，人们登楼便会生出离京怀乡、担忧谗毁的悲伤；而在春和景明、皓月千里时，人们登楼又会感到心胸开阔、宠辱皆忘的喜悦。",
        "作者由景入情，最后提出古仁人应当不以外物和个人得失而悲喜，在朝忧民，在野忧君，以“先天下之忧而忧，后天下之乐而乐”收束全文。"
      ],
      "notes": [
        {
          "term": "谪守",
          "text": "因贬官而外任地方官。"
        },
        {
          "term": "百废具兴",
          "text": "许多已经荒废的事业都兴办起来。具，同“俱”。"
        },
        {
          "term": "胜状",
          "text": "胜景，好景象。"
        },
        {
          "term": "浩浩汤汤",
          "text": "水势浩大。汤汤，这里读 shāng shāng。"
        },
        {
          "term": "迁客骚人",
          "text": "被贬谪的官员和善于辞赋的文人。"
        },
        {
          "term": "不以物喜，不以己悲",
          "text": "不因为外物好坏和个人得失而或喜或悲。"
        },
        {
          "term": "微斯人，吾谁与归",
          "text": "如果没有这样的人，我同谁一道呢？"
        }
      ],
      "appreciation": [
        "这篇文章通过“悲景”与“喜景”的强烈对照，把作者的政治理想推向全文中心。它的名句之所以有力量，不仅因为判断铿锵，更因为前面已经积累了足够厚重的景与情。",
        "把古文拆成单字格并加上逐字拼音，会明显放大朗读节奏。这个界面因此既像阅读页面，又像诵读教具，适合课堂、打印和展示。"
      ],
      "recite": [
        "第一段：交代缘起。",
        "第二段：总写洞庭湖大观。",
        "第三段：霪雨霏霏，对应悲。",
        "第四段：春和景明，对应喜。",
        "第五段：升华主旨，重点背诵“先天下之忧而忧，后天下之乐而乐”。"
      ]
    },
    "桃花源记": {
      "aliases": [],
      "translation": [
        "东晋太元年间，武陵有个渔人顺着溪水划船，忘记了路程远近。",
        "他忽然遇见一片桃花林，继续前行，发现山有小口，进入后豁然开朗，看见与外界隔绝而安乐自足的村落。",
        "村中人自称祖先为避秦乱来到这里，从此不再出去，因此不知汉魏晋。渔人离开后做了标记，再去寻找却迷失了。"
      ],
      "notes": [
        {
          "term": "缘溪行",
          "text": "沿着溪水前进。"
        },
        {
          "term": "落英缤纷",
          "text": "落花繁多的样子。"
        },
        {
          "term": "俨然",
          "text": "整齐的样子。"
        },
        {
          "term": "不足为外人道也",
          "text": "不值得对外面的人说。"
        }
      ],
      "appreciation": [
        "《桃花源记》把理想社会写得不靠口号，而是靠道路、房舍、耕作和人情去落地，所以后世读者会觉得这个世界既朴素又可信。"
      ],
      "recite": [
        "抓住三次转折：入林、入洞、出洞。",
        "重点句：阡陌交通，鸡犬相闻。",
        "结尾句：后遂无问津者。"
      ]
    },
    "陋室铭": {
      "aliases": [],
      "translation": [
        "山不在于高，有仙人就出名；水不在于深，有龙就显灵。这是间简陋的屋子，只因为居住者品德高尚就显得香远益清。",
        "苔痕爬上台阶呈现绿意，草色映入帘内一片青翠。来往谈笑的都是博学之士，没有浅薄之人。",
        "可以弹奏素琴，浏览佛经，没有嘈杂音乐扰耳，也没有公文劳形。"
      ],
      "notes": [
        {
          "term": "馨",
          "text": "这里指品德高尚带来的芳香。"
        },
        {
          "term": "鸿儒",
          "text": "博学的人。"
        },
        {
          "term": "白丁",
          "text": "没有功名的人。"
        },
        {
          "term": "何陋之有",
          "text": "有什么简陋的呢。"
        }
      ],
      "appreciation": [
        "全文篇幅极短，却把环境、交游、情趣与精神格调都压缩进去，句式整齐，非常适合做格子排版和朗读展示。"
      ],
      "recite": [
        "开头两句类比起兴。",
        "中间三组对比突出陋室不陋。",
        "结尾借孔子语收束。"
      ]
    },
    "春晓": {
      "aliases": [],
      "author": "孟浩然",
      "translation": [
        "春意绵绵好睡觉，不知不觉天亮了；",
        "猛然一觉惊醒来，到处是鸟儿啼叫。",
        "夜里迷迷胡胡，似乎有沙沙风雨声；",
        "呵风雨风雨，花儿不知吹落了多少？"
      ],
      "notes": [
        {
          "term": "春晓",
          "text": "春天的旱晨。"
        }
      ]
    },
    "次北固山下": {
      "aliases": [],
      "author": "王湾",
      "translation": [
        "游客路过苍苍的北固山下，",
        "船儿泛着湛蓝的江水向前。",
        "春潮正涨两岸江面更宽阔，",
        "顺风行船恰好把帆儿高悬。",
        "红日冲破残夜从海上升起，",
        "江上春早年底就春风拂面。",
        "寄去的家书不知何时到达，",
        "请问归雁几时飞到洛阳边。"
      ],
      "notes": [
        {
          "term": "次",
          "text": "停留。"
        },
        {
          "term": "残夜",
          "text": "天快亮时。"
        },
        {
          "term": "江春句",
          "text": "还没到新年江南就有了春天的音讯。"
        },
        {
          "term": "归雁句",
          "text": "古时传说雁能带信，这句的意思是希望北归的大雁能将家信带到故乡洛阳。"
        }
      ]
    },
    "木兰诗": {
      "aliases": [
        "木兰辞"
      ],
      "author": "佚名"
    },
    "记承天寺夜游": {
      "aliases": [],
      "author": "苏轼",
      "translation": [
        "元丰六年十月十二日夜晚（或公元1083年十月十二日夜，可不译），（我）脱下衣服准备睡觉时，恰好看见月光透过窗户洒入屋内，（于是我）高兴地起床出门散步。想到没有（可以与我）共同游乐的人，于是（我）前往承天寺寻找张怀民。张怀民也没有睡，我们便一同在庭院中散步。庭院中充满着月光，像积水充满院落，清澈透明，水中的水藻、荇菜交横错杂，原来是竹子和柏树的影子啊。哪一个夜晚没有月光？（又有）哪个地方没有松柏树呢？只是缺少像我们两个这样（不汲汲于名利而又能从容流连光景）清闲的人罢了。"
      ],
      "notes": [
        {
          "term": "承天寺",
          "text": "故址在今湖北黄冈县城南。"
        },
        {
          "term": "元丰六年",
          "text": "公元1083年。元丰，宋神宗赵顼年号。当时作者因乌台诗案被贬黄州已经四年。 解：把系着的东西解开。"
        },
        {
          "term": "欲",
          "text": "想要。"
        },
        {
          "term": "户",
          "text": "一说指堂屋的门，又一说指窗户，这里指门。"
        },
        {
          "term": "欣然",
          "text": "高兴、愉快的样子。欣，高兴，愉快。然，……的样子。"
        },
        {
          "term": "行",
          "text": "散步。"
        },
        {
          "term": "念无与为乐者",
          "text": "想到没有可以共同游乐的人。念，考虑，想到。 无与乐者，没有可以共同游乐的人。者：……的人。"
        },
        {
          "term": "遂",
          "text": "于是，就。"
        },
        {
          "term": "至",
          "text": "到。"
        },
        {
          "term": "寻",
          "text": "寻找。"
        },
        {
          "term": "张怀民",
          "text": "作者的朋友。名梦得，字怀民，清河（今河北清河）人。元丰六年也被贬到黄州，寓居承天寺。"
        },
        {
          "term": "寝",
          "text": "睡，卧。"
        },
        {
          "term": "相与步于中庭",
          "text": "一同走到庭院中，相与，共同，一同。步：散步。中庭，庭院里。"
        },
        {
          "term": "庭下如积水空明",
          "text": "意思是月色洒满庭院，如同积水充满院落，清澈透明。"
        },
        {
          "term": "空明",
          "text": "形容水的澄澈。在这里形容月色如水般澄净明亮的样子。"
        },
        {
          "term": "藻、荇（xìng",
          "text": "均为水生植物，这里是水草。藻，水草的总称。荇，一种多年生水草，叶子像心脏形，面绿背紫，夏季开黄花。"
        },
        {
          "term": "交横",
          "text": "交错纵横。"
        },
        {
          "term": "盖",
          "text": "句首语气词，这里可以译为“原来是”。"
        },
        {
          "term": "也",
          "text": "是。"
        },
        {
          "term": "但少闲人",
          "text": "只是缺少清闲的人。但，只。"
        },
        {
          "term": "闲",
          "text": "清闲。"
        },
        {
          "term": "闲人",
          "text": "这里是指不汲汲于名利而能从容流连光景的人。苏轼这时被贬为黄州团练副使，这里是一个有职无权的官，所以他十分清闲，自称“闲人”。"
        },
        {
          "term": "耳",
          "text": "语气词, 相当于“而已”意思是“罢了”。"
        }
      ]
    },
    "爱莲说": {
      "aliases": [],
      "author": "周敦颐",
      "translation": [
        "水上和陆地上草本木本的花中，可以喜爱的有很多。晋代陶渊明唯独喜爱菊花。自从唐朝以来，世上的人们很喜爱牡丹。我唯独喜欢莲花,它从淤泥中生长出来，却不受淤泥的沾染；它经过清水的洗涤后，却不显得妖媚。它的茎中间是贯通的，外形是笔直的，不生枝蔓，不长枝节。香气传播得越远越清幽，它笔直洁净地立在那里，（人们）可以远远地观赏它们，却不可靠近去玩弄它。",
        "我认为，菊花，是花中的隐士；牡丹，是花中的富贵的花；莲花，是花中的君子。唉!（感叹词，在此作助词，以加重语气。）对于菊花的喜爱，在陶渊明之后就很少听说了。对于莲花的喜爱，像我一样的还有什么人？对于牡丹的喜爱，人该是很多了。"
      ],
      "notes": [
        {
          "term": "晋陶渊明独爱菊",
          "text": "晋朝陶渊明只喜爱菊花。陶渊明(365-427)，一名潜，字元亮，自称五柳先生，世称靖节先生，东晋浔阳柴桑(现在江西省九江县)人，东晋著名诗人。是著名的隐士。他独爱菊花，常在诗里咏菊，如《饮酒》诗里的“采菊东篱下，悠然见南山”，向来称为名句。"
        },
        {
          "term": "自李唐来，世人甚爱牡丹",
          "text": "从唐朝以来，人们很爱牡丹。李唐，指唐朝。唐朝的皇帝姓李，所以称为“李唐”。世人，社会上的一般人。唐人爱牡丹，古书里有不少记载，如唐朝李肇的《唐国史补》里说：“京城贵游，尚牡丹……每春暮，车马若狂……种以求利，一本(一株)有直(同“值”)数万(指钱)者。”盛：特别，十分。甚：很，十分。"
        },
        {
          "term": "之",
          "text": "的。"
        },
        {
          "term": "可",
          "text": "值得。"
        },
        {
          "term": "者",
          "text": "花。"
        },
        {
          "term": "蕃",
          "text": "通“繁”多"
        },
        {
          "term": "独",
          "text": "只，唯独。"
        },
        {
          "term": "自",
          "text": "自从。"
        },
        {
          "term": "予（yú",
          "text": "我。"
        },
        {
          "term": "之",
          "text": "助词，用于主谓之间，取消句子独立性，无实际意义。"
        },
        {
          "term": "淤泥",
          "text": "河沟或池塘里积存的污泥。"
        },
        {
          "term": "染",
          "text": "沾染。"
        },
        {
          "term": "濯（zhuó",
          "text": "洗涤。"
        },
        {
          "term": "清涟（lián",
          "text": "水清而有微波，这里指清水。"
        },
        {
          "term": "妖",
          "text": "妖艳。"
        },
        {
          "term": "焉",
          "text": "声词，相当于现在的“啊”。"
        },
        {
          "term": "李唐",
          "text": "指唐朝。唐朝皇帝姓李所以称为“李唐”。"
        },
        {
          "term": "通",
          "text": "空。"
        },
        {
          "term": "直",
          "text": "挺立。"
        },
        {
          "term": "中通外直",
          "text": "（它的茎）内空外直。"
        },
        {
          "term": "不蔓(màn)不枝",
          "text": "不生枝蔓，不长枝节。"
        },
        {
          "term": "蔓",
          "text": "名词用作动词，生枝蔓。"
        },
        {
          "term": "枝",
          "text": "名词用作动词，长枝节。"
        },
        {
          "term": "香远益清",
          "text": "香气远播，更加显得清芬。"
        },
        {
          "term": "远",
          "text": "遥远，空间距离大，远播，远远的传送出去。"
        },
        {
          "term": "益",
          "text": "更，更加。"
        },
        {
          "term": "亭亭净植",
          "text": "笔直地洁净地立在那里。亭亭：耸立的样子。植：“植”通“直”，立。"
        },
        {
          "term": "近",
          "text": "靠近，走近（形容词）。"
        },
        {
          "term": "可",
          "text": "只能。"
        },
        {
          "term": "亵(xiè",
          "text": "亲近而不庄重。"
        },
        {
          "term": "玩",
          "text": "玩弄。"
        },
        {
          "term": "谓",
          "text": "认为。"
        },
        {
          "term": "隐逸者",
          "text": "指隐居的人。在封建社会里，有些人不愿意跟统治者同流合污，就隐居避世;"
        },
        {
          "term": "君子",
          "text": "指品德高尚的人。"
        },
        {
          "term": "者",
          "text": "……的人或物。随着前面的名词而变化，例如：“有黄鹤楼者”中的者意思就是……建筑"
        },
        {
          "term": "噫",
          "text": "感叹词,相当于现在的\"啊\"。"
        },
        {
          "term": "菊之爱",
          "text": "对于菊花的喜爱。之：语气助词，的。（一说为“宾语提前的标志”）"
        },
        {
          "term": "鲜(xiǎn",
          "text": "少。"
        },
        {
          "term": "闻",
          "text": "听说。"
        },
        {
          "term": "同予者何人",
          "text": "像我一样的还有什么人呢？"
        },
        {
          "term": "宜乎众矣",
          "text": "（爱牡丹的）人应该是很多了。宜乎：当然。宜：应当。众：多。"
        }
      ]
    },
    "三峡": {
      "aliases": [],
      "author": "郦道元",
      "notes": [
        {
          "term": "1）自",
          "text": "在，从"
        },
        {
          "term": "三峡",
          "text": "指长江上游重庆、湖北两省间的瞿塘峡、巫峡和西陵峡。三峡全长实际只有四百多里。"
        },
        {
          "term": "2）略无",
          "text": "完全没有。阙：通“缺”，中断 。"
        },
        {
          "term": "3) 嶂(zhàng",
          "text": "高峻险拔如屏障一样的山峰。"
        },
        {
          "term": "4）自非",
          "text": "如果不是。自：如果。非：不是"
        },
        {
          "term": "5）亭午",
          "text": "正午。夜分：半夜。"
        },
        {
          "term": "6）曦(xī",
          "text": "日光，这里指太阳。（7）襄（xiāng），上。 陵，丘陵，小山包"
        },
        {
          "term": "8）沿",
          "text": "顺流而下（的船）。溯(sù)：逆流而上（的船）。"
        },
        {
          "term": "9）或",
          "text": "有时。王命：皇帝的圣旨。宣：宣布，传达。"
        },
        {
          "term": "10） 朝发白帝",
          "text": "早上从白帝城出发。白帝：城名，在重庆奉节东。朝：早晨"
        },
        {
          "term": "11）江陵",
          "text": "今湖北省江陵县。"
        },
        {
          "term": "12）虽",
          "text": "即使。 奔：奔驰的马。御：驾着"
        },
        {
          "term": "13）不以",
          "text": "不如。此句谓和行船比起来，即使是乘奔御风也不被认为是（比船）快，或为“以”当是“似”之误。(见清赵一清《水经注刊误》) 疾：快。"
        },
        {
          "term": "14）素湍",
          "text": "白色的急流。素：白色的。绿潭：碧绿的潭水。"
        },
        {
          "term": "15）回清倒影",
          "text": "回旋的清波，倒映出山石林木的倒影。"
        },
        {
          "term": "16）绝巘(yǎn):极高的山峰。绝",
          "text": "极高。巘：山峰"
        },
        {
          "term": "17）悬泉",
          "text": "悬挂着的泉水瀑布。飞漱：急流冲荡。漱：冲刷。"
        },
        {
          "term": "18）清荣峻茂",
          "text": "水清，树荣，山高，草盛。"
        },
        {
          "term": "19) 良",
          "text": "实在，的确。"
        },
        {
          "term": "20) 晴初",
          "text": "天刚晴。霜旦：下霜的早晨。"
        },
        {
          "term": "21）属引",
          "text": "连续不断。属(zhǔ)：动词。连接。引：延长。凄异：凄凉怪异。"
        },
        {
          "term": "22）哀转久绝",
          "text": "悲哀婉转，很久才消失。绝：消失。"
        },
        {
          "term": "23）巴东",
          "text": "汉郡名，在现在重庆东部云阳，奉节，巫山一带。"
        },
        {
          "term": "24) 沾",
          "text": "打湿。"
        },
        {
          "term": "25) 三声",
          "text": "几声。这里不是确数"
        },
        {
          "term": "26) 裳（cháng",
          "text": "衣裳。"
        }
      ]
    },
    "孙权劝学": {
      "aliases": [],
      "author": "司马光 撰",
      "translation": [
        "当初，孙权对吕蒙说：“你现在当权掌管政事，不可以不学习！”吕蒙用军中事务繁多的理由来推托。孙权说：“我难道是想要你研究儒家经典成为传授经书的学官吗？只是应当粗略地阅读，了解历史罢了。你说军中事务繁多，谁能比得上我呢？我经常读书，（我）自认为（读书对我）有很大的好处。”吕蒙于是就开始学习。等到鲁肃到寻阳的时候，和吕蒙论议国家大事，（鲁肃）惊讶地说：“你现在的才干和谋略，不再是以前那个吴县的阿蒙了！”吕蒙说：“和有抱负的人分开一段时间后，就要用新的眼光来看待，长兄怎么认清事物这么晚啊！”于是鲁肃拜见吕蒙的母亲，与吕蒙结为朋友才分别。"
      ],
      "notes": [
        {
          "term": "初",
          "text": "当初，这里是追述往事的习惯用词。"
        },
        {
          "term": "权",
          "text": "指孙权，字仲谋，黄龙元年（公元222年）称王于建业（今江苏南京），国号吴，不久迁都武昌（今湖北鄂城）。229年称帝。"
        },
        {
          "term": "谓",
          "text": "告诉，对……说，常与“曰”连用。"
        },
        {
          "term": "卿",
          "text": "古代君对臣或长辈对晚辈的爱称。"
        },
        {
          "term": "今",
          "text": "现在。"
        },
        {
          "term": "涂",
          "text": "同“途”。当涂掌事：当涂，当道，即当权的意思。掌事，掌管政事（异议：当涂：地名）。"
        },
        {
          "term": "辞",
          "text": "推托。"
        },
        {
          "term": "多务",
          "text": "事务多，杂事多。务，事务。"
        },
        {
          "term": "孤",
          "text": "古时候王侯的自称。"
        },
        {
          "term": "治经",
          "text": "研究儒家经典。\"经”指四书五经，四书：《大学》《中庸.》《论语》《孟子》，五经：《诗经》《尚书》《礼记》《易经》《春秋》"
        },
        {
          "term": "博士",
          "text": "当时专掌经学传授的学官。"
        },
        {
          "term": "但",
          "text": "只，仅。"
        },
        {
          "term": "涉猎",
          "text": "粗略地阅读"
        },
        {
          "term": "见往事",
          "text": "了解历史。见，了解；往事，指历史。"
        },
        {
          "term": "乃",
          "text": "于是，就。"
        },
        {
          "term": "及",
          "text": "到了…的时候。"
        },
        {
          "term": "过",
          "text": "到；到达。"
        },
        {
          "term": "寻阳",
          "text": "县名，现在湖北黄梅西南。"
        },
        {
          "term": "才略",
          "text": "军事方面或政治方面的才干和谋略。"
        },
        {
          "term": "非复",
          "text": "不再是。"
        },
        {
          "term": "大兄",
          "text": "长兄，这里是对同辈年长者的尊称。"
        },
        {
          "term": "但",
          "text": "只，仅。"
        },
        {
          "term": "孰若",
          "text": "谁比的上；谁像（我）。孰：谁，若：像。"
        },
        {
          "term": "就",
          "text": "从事。"
        },
        {
          "term": "遂",
          "text": "于是，就。"
        },
        {
          "term": "士别三日",
          "text": "有抱负的人分别几天。三：几天，这里指“少”（与常见的“多”的解释不同）。"
        },
        {
          "term": "何",
          "text": "为什么。"
        },
        {
          "term": "吕蒙",
          "text": "东吴名将，汝南富陂（今安徽阜阳）人"
        },
        {
          "term": "耳",
          "text": "表示限制，语气词，相当于“罢了”。"
        },
        {
          "term": "始",
          "text": "开始。"
        },
        {
          "term": "与",
          "text": "和。"
        },
        {
          "term": "论议",
          "text": "谈论，商议。"
        },
        {
          "term": "大",
          "text": "非常，十分。"
        },
        {
          "term": "惊",
          "text": "惊奇。"
        },
        {
          "term": "今",
          "text": "现在。"
        },
        {
          "term": "者",
          "text": "用在时间词后面，无翻译。"
        },
        {
          "term": "复",
          "text": "再。"
        },
        {
          "term": "即",
          "text": "就。"
        },
        {
          "term": "拜",
          "text": "拜见。"
        },
        {
          "term": "待",
          "text": "等待。"
        },
        {
          "term": "吴下阿蒙",
          "text": "三国时吴国名将吕蒙，对吕蒙亲昵的称呼；在吴下时的没有文学的阿蒙。"
        },
        {
          "term": "刮目相待",
          "text": "用新的眼光看待，即另眼相看。 刮目：擦擦眼睛。"
        },
        {
          "term": "更",
          "text": "重新。"
        },
        {
          "term": "阿蒙",
          "text": "名字前加“阿”，有亲昵的意味。"
        },
        {
          "term": "邪（yé",
          "text": "通“耶”，语气词。"
        },
        {
          "term": "乎",
          "text": "啊。表感叹语气。"
        },
        {
          "term": "以",
          "text": "用"
        },
        {
          "term": "见事",
          "text": "认清事物"
        }
      ]
    },
